{
  // LiteLLM 本地代理配置
  "provider": {
    "litellm": {
      "api_key": "sk-no-key-needed",
      "base_url": "http://localhost:4000/v1",
      "models": [
        {
          "id": "ds-deepseek-v4-flash",
          "context_limit": 1000000,
          "max_output_tokens": 384000,
          "timeout": 300,
          "temperature": 0.7
        }
      ]
    }
  },

  "agent": {
    "system_prompt": "你是一个有用的AI助手，请用中文回答问题。",
    "default_model": "ds-deepseek-v4-flash",
    "streaming": true,
    "recursion_limit": 1000
  },

  "database": {
    "url": "sqlite+aiosqlite:///./lc_agent_data.db",
    "checkpoint_path": "./lc_agent_checkpoints.db"
  },

  "skills": ["./skills"],

  "mcp_servers": {},
      // ----- UI -----
  "ui": {
      // 网页左上角显示的应用名称，默认 "lc_agent"
      "app_name": "运维助手"
  },
    // ----- 登录认证 -----
  "auth": {
      // 设为 true 后需要管理员账号密码登录。
      // 启用时请填写真实值，或改用 {env:LC_AGENT_ADMIN_PASSWORD} / {env:LC_AGENT_SESSION_SECRET}
      "enabled": false,
      "admin_username": "admin",
      "admin_password": "123",
      "session_secret": "ASDQWE",
      "cookie_name": "lc_agent_session",
      "session_ttl_seconds": 28800,
      "cookie_secure": true
  },
}
